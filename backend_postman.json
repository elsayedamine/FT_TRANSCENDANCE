{
  "info": {
    "name": "Backend API",
    "_postman_id": "12345678-aaaa-bbbb-cccc-123456789abc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/users/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test\",\n  \"password\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Login (Get Tokens)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/token/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test\",\n  \"password\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/token/refresh/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh\": \"<refresh_token>\"\n}"
        }
      }
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access}}"
          }
        ],
        "url": "{{base_url}}/api/users/me/"
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access}}"
          }
        ],
        "url": "{{base_url}}/api/users/profile/me/"
      }
    },
    {
      "name": "Update Profile",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access}}"
          }
        ],
        "url": "{{base_url}}/api/users/profile/me/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"display_name\": \"KING\",\n  \"bio\": \"builder\"\n}"
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access}}"
          }
        ],
        "url": "{{base_url}}/api/users/logout/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh\": \"<refresh_token>\"\n}"
        }
      }
    }
  ]
}